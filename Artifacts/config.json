{
  "dataset_source": "huggingface",
  "d1_dataset_name": "YinkaiW/harmbench-dataset",
  "d2_dataset_name": "JailbreakV-28K/JailBreakV-28k",
  "d2_dataset_config": "JailBreakV_28K",
  "train_size": 0.7,
  "val_size": 0.15,
  "test_size": 0.15,
  "classifier_model_name": "distilbert-base-uncased",
  "sbert_model_name": "sentence-transformers/all-MiniLM-L6-v2",
  "zero_shot_model_name": "facebook/bart-large-mnli",
  "learning_rate": 2e-05,
  "epochs": 5,
  "batch_size": 16,
  "top_k": 5,
  "w1": 0.5,
  "w2": 0.25,
  "w3": 0.25,
  "theta": 0.5,
  "delta": 0.08,
  "max_length": 64,
  "early_stopping_patience": 2,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "max_grad_norm": 1.0,
  "embedding_batch_size": 128,
  "zero_shot_batch_size": 8,
  "translation_batch_size": 16,
  "weight_grid_step": 0.05,
  "output_dir": "/content/sentra_guard_artifacts",
  "text_column_candidates": [
    "prompt",
    "text",
    "content",
    "instruction",
    "input",
    "query",
    "message",
    "user_prompt",
    "sentence",
    "question",
    "jailbreak_query"
  ],
  "label_column_candidates": [
    "label",
    "labels",
    "class",
    "target",
    "is_harmful",
    "binary_label",
    "prompt_type"
  ],
  "translation_models": {
    "bn": "Helsinki-NLP/opus-mt-bn-en",
    "es": "Helsinki-NLP/opus-mt-es-en",
    "hi": "Helsinki-NLP/opus-mt-hi-en",
    "ar": "Helsinki-NLP/opus-mt-ar-en",
    "zh": "Helsinki-NLP/opus-mt-zh-en"
  },
  "selected_w1": 0.35,
  "selected_w2": 0.5,
  "selected_w3": 0.15,
  "selected_theta": 0.35,
  "selected_delta": 0.08,
  "seed": 42
}